    {
      "type": "text",
      "id": "wave_guide_content",
      "x": 81.6875,
      "y": 1474.77734375,
      "width": 400,
      "height": 120,
      "text": "Wave 0: Bootstrap apps (appprojects-app, root-app)\nWave 2: Sealed Secrets, Namespaces, AppProject CRs\nWave 3: Infra Secrets, ArgoCD Config\nWave 4: cert-manager, Traefik, Reflector, Alloy, Tailscale, NewRelic\nWave 5: Workload applications (sample-app, microservice, postgresql, immich, tailscale-op)",
      "originalText": "Wave 0: Bootstrap apps (appprojects-app, root-app)\nWave 2: Sealed Secrets, Namespaces, AppProject CRs\nWave 3: Infra Secrets, ArgoCD Config\nWave 4: cert-manager, Traefik, Reflector, Alloy, Tailscale, NewRelic\nWave 5: Workload applications (sample-app, microservice, postgresql, immich, tailscale-op)",
      "fontSize": 12,
