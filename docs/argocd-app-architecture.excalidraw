    {
      "type": "text",
      "id": "networking_detail",
      "x": 89.3212890625,
      "y": 1289.921875,
      "width": 400,
      "height": 80,
      "text": "Traefik Routing (prod):\nargocd.newyeti.qzz.io --> ArgoCD Server (strip /argocd)\ntraefik-a.newyeti.qzz.io --> Dashboard tenant-a\ntraefik-b.newyeti.qzz.io --> Dashboard tenant-b\nimmich.newyeti.qzz.io --> immich-prod-tenant-b-server:2283",
      "originalText": "Traefik Routing (prod):\nargocd.newyeti.qzz.io --> ArgoCD Server (strip /argocd)\ntraefik-a.newyeti.qzz.io --> Dashboard tenant-a\ntraefik-b.newyeti.qzz.io --> Dashboard tenant-b\nimmich.newyeti.qzz.io --> immich-prod-tenant-b-server:2283",
